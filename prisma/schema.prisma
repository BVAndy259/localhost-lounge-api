// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(100)
  email         String        @unique @db.VarChar(100)
  password_hash String        @db.VarChar(255)
  role          String        @default("RECEPCIONISTA") @db.VarChar(50)
  active        Boolean       @default(true)
  reservations  Reservation[]

  @@map("users")
}

model Waiter {
  id     Int     @id @default(autoincrement())
  name   String  @db.VarChar(100)
  active Boolean @default(true)
  tables Table[]

  @@map("waiters")
}

model Client {
  id                 Int            @id @default(autoincrement())
  name               String         @db.VarChar(100)
  last_name          String         @db.VarChar(100)
  email              String         @unique @db.VarChar(100)
  phone_number       String         @unique @db.VarChar(20)
  total_reservations Int            @default(0)
  category           String         @default("NUEVO") @db.VarChar(20)
  reservations       Reservation[]
  chat_sessions      Chat_Session[]

  @@map("clients")
}

model Table {
  id                Int           @id @default(autoincrement())
  waiter_id         Int?
  table_number      Int           @unique
  capacity          Int
  type              String        @db.VarChar(20)
  reservation_price Decimal       @default(0.00) @db.Decimal(10, 2)
  description       String        @db.Text()
  active            Boolean       @default(true)
  status            String        @default("LIBRE")
  waiter            Waiter?       @relation(fields: [waiter_id], references: [id], onDelete: SetNull)
  reservations      Reservation[]

  @@map("tables")
}

model Reservation {
  id               Int      @id @default(autoincrement())
  client_id        Int
  table_id         Int
  receptionist_id  Int?
  reservation_date DateTime @db.Date
  reservation_time DateTime @db.Time
  number_people    Int
  status           String   @default("PENDIENTE") @db.VarChar(20)
  notes            String   @db.Text
  created_on       DateTime @default(now())
  client           Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  table            Table    @relation(fields: [table_id], references: [id])
  receptionist     User?    @relation(fields: [receptionist_id], references: [id], onDelete: SetNull)

  @@map("reservations")
}

model Plate {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  description String? @db.Text
  price       Decimal @db.Decimal(10, 2)
  category    String  @db.VarChar(50)
  available   Boolean @default(true)
  image_url   String? @db.Text

  @@map("plates")
}

model Chat_Session {
  id            Int            @id @default(autoincrement())
  session_token String         @unique @db.VarChar(255)
  client_id     Int?
  created_on    DateTime       @default(now())
  client        Client?        @relation(fields: [client_id], references: [id], onDelete: SetNull)
  messages      Chat_Message[]

  @@map("chat_sessions")
}

model Chat_Message {
  id         Int          @id @default(autoincrement())
  session_id Int
  role       String       @db.VarChar(20)
  content    String       @db.Text
  created_on DateTime     @default(now())
  sesion     Chat_Session @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "module": "CommonJS",
    "target": "es2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*", 
    "prisma/**/*"
  ],
  "exclude": [
    "node_modules", 
    "dist"
  ]
}